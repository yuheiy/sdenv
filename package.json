{
  "name": "my-website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "check": "astro sync && astro check && pnpm run fmt --check && pnpm run lint",
    "check:fix": "astro sync && astro check && pnpm run lint --fix && pnpm run fmt",
    "dev": "astro dev",
    "fmt": "prettier --write . --log-level warn",
    "lint": "eslint",
    "preview": "astro preview",
    "test": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "@yuheiy/postcss-custom-functions": "^0.1.1",
    "alpinejs": "^3.15.10",
    "astro": "^6.1.3",
    "astro-icon": "^1.1.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/alpinejs": "^3.13.11",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.14.1",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
